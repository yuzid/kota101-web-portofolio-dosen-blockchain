{
  "family": "portfolio-server-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::AWS_ACCOUNT_ID:role/service-role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "portfolio-server-container",
      "image": "AWS_ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/portofolio-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "PORT", "value": "3000"},
        {"name": "NODE_ENV", "value": "production"},
        {"name": "DB_HOST", "value": "DB_HOST_PLACEHOLDER"},
        {"name": "DB_USER", "value": "DB_USER_PLACEHOLDER"},
        {"name": "DB_PASSWORD", "value": "DB_PASSWORD_PLACEHOLDER"},
        {"name": "DB_NAME", "value": "DB_NAME_PLACEHOLDER"},
        {"name": "MULTICHAIN_RPC_URL", "value": "MULTICHAIN_RPC_URL_PLACEHOLDER"},
        {"name": "AWS_S3_BUCKET", "value": "AWS_S3_BUCKET_PLACEHOLDER"}
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/api/status || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/portofolio-server",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}