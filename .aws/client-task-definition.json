{
  "family": "portfolio-client-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::AWS_ACCOUNT_ID:role/service-role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "portfolio-client-container",
      "image": "AWS_ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/portofolio-client:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "NGINX_PORT", "value": "80"}
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost/api/status || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 45
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/portfolio-client",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}