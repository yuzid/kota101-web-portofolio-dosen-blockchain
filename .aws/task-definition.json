{
  "family": "portfolio-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "portfolio-server-container",
      "image": "<NOMOR_AKUN_AWS>.dkr.ecr.us-east-1.amazonaws.com/portfolio-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ]
    },
    {
      "name": "portfolio-client-container",
      "image": "<NOMOR_AKUN_AWS>.dkr.ecr.us-east-1.amazonaws.com/portfolio-client:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ]
    }
  ]
}