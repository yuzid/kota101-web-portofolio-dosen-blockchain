{
  "family": "portfolio-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::AWS_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "portfolio-server-container",
      "image": "AWS_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/portfolio-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ]
    },
    {
      "name": "portfolio-client-container",
      "image": "AWS_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/portfolio-client:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}